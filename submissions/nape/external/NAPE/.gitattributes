# Default: normalize line endings to LF on commit, check out native on Windows.
* text=auto eol=lf

# Always-binary files
*.png binary
*.xlsx binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Treat shell scripts as LF always (don't let Windows clobber them)
*.sh text eol=lf
*.ps1 text eol=crlf
